# Внешний API тестового задания
EXTERNAL_API_BASE_URL=http://91.199.149.128:18001
X_CANDIDATE_ID=your_candidate_id

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://files:files@db:5432/files_db

# App
APP_HOST=0.0.0.0
APP_PORT=8000
# Добавь свой публичный URL после деплоя, например: http://YOUR_SERVER_IP:8088
CORS_ORIGINS=http://localhost:8088,http://127.0.0.1:8088
FILES_STORAGE_DIR=/app/data/files

# HTTP-порт на хосте (docker compose)
APP_HOST_PORT=8088

# Rate-limit к внешнему API
EXTERNAL_API_MIN_INTERVAL_SECONDS=1.5
EXTERNAL_API_RETRY_BUFFER_SECONDS=1.0
EXTERNAL_API_MAX_RETRIES=20
