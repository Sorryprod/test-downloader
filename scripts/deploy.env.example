# SSH / deploy (локально). Скопируй в deploy.env и заполни.
# scripts/deploy.env в .gitignore — не коммитить.

SSH_HOST=YOUR_SERVER_IP
SSH_PORT=22
SSH_USER=root
SSH_PASSWORD=YOUR_SSH_PASSWORD

REMOTE_APP_DIR=/root/test-downloader
APP_HOST_PORT=8088

# Публичный HTTPS clone (репозиторий public)
GIT_REPO_URL=https://github.com/Sorryprod/test-downloader.git
